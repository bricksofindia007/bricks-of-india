# BOI Environment Variables — copy to .env.local and fill in real values
# Never commit .env.local to git.

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to expose in browser; row-level security enforces access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — server-side only, bypasses RLS; keep secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── LEGO Data APIs ────────────────────────────────────────────────────────────
# Rebrickable API key — https://rebrickable.com/api/ → "Generate API Key"
REBRICKABLE_API_KEY=your-rebrickable-api-key-here

# Brickset API key — https://brickset.com/tools/webservices/requestkey
BRICKSET_API_KEY=your-brickset-api-key-here

# ─── LLM (Google Gemini) ──────────────────────────────────────────────────────
# Gemini API key — https://aistudio.google.com/app/apikey
# Free tier: 1,000 requests/day. Model: gemini-2.5-flash-lite
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
# Gmail account used as the morning-brief sender
GMAIL_USER=bricksofindia007@gmail.com

# App password (not your Gmail login password) — see docs/runbooks/CONTENT-PIPELINE-SETUP.md
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Password for /admin routes — 16+ characters recommended, no spaces
ADMIN_PASSWORD=your-secure-admin-password-here

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID — GA4 dashboard → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Site ─────────────────────────────────────────────────────────────────────
# Canonical site URL — no trailing slash
NEXT_PUBLIC_SITE_URL=https://bricksofindia.com

# ─── Netlify (LEGACY — pending removal in ADMIN-CLEANUP-01) ──────────────────
# Netlify personal access token — https://app.netlify.com/user/applications/personal
NETLIFY_AUTH_TOKEN=your-netlify-auth-token-here

# Netlify site ID — found in Site Settings → General → Site information
NETLIFY_SITE_ID=your-netlify-site-id-here
